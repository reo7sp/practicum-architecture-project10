@startuml
!include <C4/C4_Container.puml>

LAYOUT_LEFT_RIGHT()

Person(analyst, "Аналитик", "Работает с разрешёнными витринами данных")
Person(steward, "Владелец данных", "Разбирает спорные поля и утверждает теги")

System_Ext(core, "Операционный контур", "Выгрузки и CDC из рабочих систем")
System_Ext(privacy, "Контур политик конфиденциальности", "Теги, политики, правила обработки данных")

System_Boundary(engine, "Контур классификации и загрузки данных") {

  Container(orch, "Оркестратор загрузки", "Apache Airflow", "Запускает пакетные загрузки, управляет этапами и блокирует продвижение данных без классификации")

  Container_Boundary(classification, "Движок классификации данных") {
    Container(profiler, "Анализ структуры данных", "Сервис", "Определяет структуру набора, новые поля, изменения схемы и базовые статистики")
    Container(rules, "Классификация по правилам", "Сервис", "Классифицирует поля по шаблонам, именам, словарям и признакам")
    Container(ml, "ML-классификатор", "Сервис", "Классифицирует неоднозначные поля")
    Container(review, "Очередь ручной разметки", "Веб-интерфейс", "Направляет спорные поля на ручную проверку и утверждение")
    Container(policy, "Применение политик обработки", "Сервис", "Применяет политики маскирования, обезличивания и маршрутизации")
  }

  ContainerDb(raw, "Сырой слой", "Object Storage", "Сырые неразмеченные данные")
  ContainerDb(quarantine, "Карантинный слой", "Object Storage", "Наборы со спорной или неполной классификацией")
  ContainerDb(trusted, "Доверенный слой", "Аналитическое хранилище", "Обработанные и размеченные данные с валидными тегами")
  ContainerDb(analytics, "Аналитический слой", "Аналитическое хранилище", "Разрешённые данные для аналитики")

  ContainerDb(catalog, "Каталог данных и Data Lineage", "PostgreSQL", "Схемы, теги, версии и происхождение данных")
  Container(metrics, "Мониторинг и метрики", "Сервис мониторинга", "Точность классификации, latency, доля ручной разметки, доля карантина и drift схемы")
}

Rel(core, orch, "Передаёт пакетные выгрузки")
Rel(orch, raw, "Загружает сырые данные")
Rel(orch, profiler, "Передаёт набор на профилирование")

Rel(profiler, rules, "Передаёт схему и признаки")
Rel(rules, ml, "Передаёт неоднозначные поля")
Rel(rules, review, "Передаёт поля без уверенной классификации")
Rel(steward, review, "Проверяет и утверждает теги")

Rel(rules, policy, "Передаёт результаты правил")
Rel(ml, policy, "Передаёт вероятностные теги")
Rel(review, policy, "Передаёт утверждённые теги")
Rel(privacy, policy, "Передаёт политики обработки")

Rel(policy, quarantine, "Направляет спорные наборы")
Rel(policy, trusted, "Загружает валидные данные")
Rel(trusted, analytics, "Передаёт разрешённые данные")
Rel(analytics, analyst, "Предоставляет витрины")

Rel_D(profiler, catalog, "Сохраняет версии схем")
Rel_D(policy, catalog, "Сохраняет теги и происхождение данных")
Rel_D(policy, metrics, "Передаёт метрики классификации")

@enduml
